pipeline {
    agent any

    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install & Build') {
            steps {
                sh '''
                    docker run --rm -v $PWD:/app -w /app node:22-alpine \
                    sh -c "node -v && npm -v && npm ci && npm run lint && npm run build"
                '''
            }
        }
    }

    post {
        success {
            archiveArtifacts artifacts: 'dist/**/*', fingerprint: true, allowEmptyArchive: true
        }
        failure {
            echo 'Pipeline thất bại'
        }
    }
}