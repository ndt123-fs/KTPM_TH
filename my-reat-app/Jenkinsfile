pipeline {
    agent any
    triggers {
        pollSCM('H/5 * * * *') // Kiểm tra mã nguồn mỗi 5 phút
    }
// nguen duy tin
    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

stage('Build React') {
          steps {
              dir('my-reat-app') {
                  sh '''
                      # 1. Tạo một file Dockerfile tạm thời để build
                      echo "FROM node:22-alpine
                      WORKDIR /app
                      COPY . .
                      RUN npm install && npm run build" > Dockerfile.temp

                      # 2. Build Image từ file tạm đó (nó sẽ copy code vào trong)
                      docker build -t my-react-app-image -f Dockerfile.temp .

                      # 3. Tạo container từ image đã build để lấy kết quả ra (nếu cần)
                      docker run --name temp-container my-react-app-image
                      
                      # 4. Copy thư mục dist từ container ra ngoài máy Jenkins để lưu Artifact
                      docker cp temp-container:/app/dist ./dist
                      
                      # 5. Dọn dẹp
                      docker rm temp-container
                  '''
              }
          }
      }
    }

    post {
        success {
            archiveArtifacts artifacts: '**/dist/**/*', allowEmptyArchive: true
        }
        failure {
            echo "Pipeline failed"
        }
    }
}