pipeline {
    agent any

    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

stage('Build React') {
          steps {
              dir('my-reat-app') {
                  sh '''
                      echo "Kiểm tra thư mục hiện tại:"
                      ls -la
                      
                      # Thử chạy trực tiếp trên môi trường Jenkins
                      npm install
                      npm run build
                  '''
              }
          }
      }
    }

    post {
        success {
            archiveArtifacts artifacts: '**/dist/**/*', allowEmptyArchive: true
        }
        failure {
            echo "Pipeline failed"
        }
    }
}